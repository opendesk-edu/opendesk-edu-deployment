---
commonAnnotations:
  {{ .Values.annotations.zammad.common | toYaml | nindent 2 }}

zammad:
  image: "ghcr.io/zammad/zammad"
  tag: "latest"
  port: 3000
  replicas: 1

  db:
    user: "zammad"
    name: "zammad"

  elasticsearch:
    port: 9200

  volumes:
    data:
      size: "1Gi"
      accessMode: "ReadWriteMany"

  resources:
    requests:
      cpu: "200m"
      memory: "512Mi"
    limits:
      cpu: "1"
      memory: "2G"

ingress:
  enabled: {{ .Values.ingress.enabled }}
  className: "haproxy"
  annotations:
    {{ .Values.annotations.zammad.ingress | toYaml | nindent 4 }}
    haproxy-ingress.github.io/ssl-redirect: "true"
    haproxy-ingress.github.io/timeout-server: "3600s"
    haproxy-ingress.github.io/timeout-client: "3600s"
    haproxy-ingress.github.io/timeout-tunnel: "3600s"
    haproxy-ingress.github.io/headers: "X-Forwarded-Host helpdesk.opendesk.example.com"
  hosts:
    - host: "helpdesk.opendesk.example.com"
      paths:
        - path: /
          pathType: "ImplementationSpecific"
  tls:
    - secretName: "opendesk-certificates-tls"
      hosts:
        - "helpdesk.opendesk.example.com"

persistence:
  size: "1Gi"
  storageClass: {{ coalesce .Values.persistence.storages.zammad.storageClassName .Values.persistence.storageClassNames.RWO | quote }}

service:
  annotations:
    {{ .Values.annotations.zammad.service | toYaml | nindent 4 }}
  externalPort: 3000
  enabled: true

serviceAccount:
  annotations:
    {{ .Values.annotations.zammad.serviceAccount | toYaml | nindent 4 }}

volumePermissions:
  enabled: true

nodeSelector: {}

tolerations: []

affinity: {}

cluster:
  replicas: {{ default 1 .Values.replicas.zammad }}

postgresql:
  enabled: true
  auth:
    username: "zammad"
    database: "zammad"
  primary:
    persistence:
      enabled: true
      size: "8Gi"

elasticsearch:
  enabled: true
