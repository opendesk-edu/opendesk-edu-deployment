---
commonAnnotations:
  {{ .Values.annotations.bookstack.common | toYaml | nindent 2 }}

bookstack:
  # Image configuration - using official LinuxServer.io BookStack image
  image: "linuxserver/bookstack"
  tag: "latest"

  # Database configuration (embedded MariaDB)
  db:
    user: "bookstack"
    # Password will be set via mariadb.auth.password
    name: "bookstack"

  # Volume configuration
  volumes:
    uploads:
      size: "1Gi"
      accessMode: "ReadWriteMany"

  # Resource configuration
  resources:
    requests:
      cpu: "100m"
      memory: "256Mi"
    limits:
      cpu: "500m"
      memory: "512Mi"

  # Replica count
  replicas: {{ default 1 .Values.replicas.bookstack }}

# Ingress configuration
ingress:
  enabled: {{ .Values.ingress.enabled }}
  className: "haproxy"
  annotations:
    {{ .Values.annotations.bookstack.ingress | toYaml | nindent 4 }}
    haproxy-ingress.github.io/ssl-redirect: "true"
    haproxy-ingress.github.io/proxy-body-size: "{{ .Values.ingress.parameters.bodySize.bookstack }}"
    haproxy-ingress.github.io/timeout-server: "{{ .Values.ingress.parameters.bodyTimeout.bookstack }}s"
    haproxy-ingress.github.io/timeout-client: "{{ .Values.ingress.parameters.bodyTimeout.bookstack }}s"
    haproxy-ingress.github.io/headers: "X-Forwarded-Host wiki.opendesk.example.com"
  hosts:
    - host: "wiki.opendesk.example.com"
      paths:
        - path: /
          pathType: "ImplementationSpecific"
  tls:
    - secretName: "opendesk-certificates-tls"
      hosts:
        - "wiki.opendesk.example.com"

# Persistence configuration
persistence:
  size: "1Gi"
  storageClass: {{ coalesce .Values.persistence.storages.bookstack.storageClassName .Values.persistence.storageClassNames.RWO | quote }}

# Service configuration
service:
  annotations:
    {{ .Values.annotations.bookstack.service | toYaml | nindent 4 }}
  externalPort: 80
  enabled: true

# Service account configuration
serviceAccount:
  annotations:
    {{ .Values.annotations.bookstack.serviceAccount | toYaml | nindent 4 }}

# Volume permissions
volumePermissions:
  enabled: true

# Node selector
nodeSelector: {}

# Tolerations
tolerations: []

# Affinity
affinity: {}

# Embedded MariaDB configuration
mariadb:
  enabled: true
  auth:
    username: "bookstack"
    # Password will be set from bookstack-database-credentials secret
    password: ""
    database: "bookstack"
  primary:
    persistence:
      enabled: true
      size: "8Gi"
      accessMode: "ReadWriteOnce"
