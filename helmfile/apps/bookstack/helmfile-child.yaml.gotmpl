---
releases:
  - name: "bookstack"
    chart: "../../charts/bookstack"
    wait: true
    values:
      - "values.yaml.gotmpl"
      {{- range .Values.customization.release.bookstack }}
      - {{ . }}
      {{- end }}
    installed: {{ .Values.apps.bookstack.enabled }}
    timeout: 1800

commonLabels:
  deployStage: "050-components"
  component: "bookstack"
