---
commonAnnotations:
  {{ .Values.annotations.excalidraw.common | toYaml | nindent 2 }}

excalidraw:
  image: excalidraw/excalidraw
  tag: latest
  port: 80

  resources:
    requests:
      cpu: 50m
      memory: 64Mi
    limits:
      cpu: 200m
      memory: 256Mi

ingress:
  enabled: {{ .Values.ingress.enabled }}
  className: "haproxy"
  annotations:
    {{ .Values.annotations.excalidraw.ingress | toYaml | nindent 4 }}
    haproxy-ingress.github.io/ssl-redirect: "true"
    haproxy-ingress.github.io/headers: "X-Forwarded-Host excalidraw.opendesk.example.com"
  hosts:
    - host: "excalidraw.opendesk.example.com"
      paths:
        - path: /
          pathType: "ImplementationSpecific"
  tls:
    - secretName: "opendesk-certificates-tls"
      hosts:
        - "excalidraw.opendesk.example.com"
