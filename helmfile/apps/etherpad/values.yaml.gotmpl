---
commonAnnotations:
  {{ .Values.annotations.etherpad.common | toYaml | nindent 2 }}

etherpad:
  image: "etherpad/etherpad"
  tag: "1.9.9"
  port: 9001
  db:
    user: "etherpad"
    name: "etherpad"
  volumes:
    data:
      size: "1Gi"
      accessMode: "ReadWriteMany"
  resources:
    requests:
      cpu: "100m"
      memory: "256Mi"
    limits:
      cpu: "500m"
      memory: "512Mi"

securityContext:
  enabled: true
  runAsUser: 0
  runAsGroup: 0

containerSecurityContext:
  enabled: true
  runAsUser: 0
  runAsGroup: 0

ingress:
  enabled: {{ .Values.ingress.enabled }}
  className: "haproxy"
  annotations:
    {{ .Values.annotations.etherpad.ingress | toYaml | nindent 4 }}
    haproxy-ingress.github.io/ssl-redirect: "true"
    haproxy-ingress.github.io/proxy-body-size: "{{ .Values.ingress.parameters.bodySize.etherpad }}"
    haproxy-ingress.github.io/timeout-server: "{{ .Values.ingress.parameters.bodyTimeout.etherpad }}s"
    haproxy-ingress.github.io/timeout-client: "{{ .Values.ingress.parameters.bodyTimeout.etherpad }}s"
    haproxy-ingress.github.io/headers: "X-Forwarded-Host etherpad.opendesk.example.com"
  hosts:
    - host: "etherpad.opendesk.example.com"
      paths:
        - path: /
          pathType: "ImplementationSpecific"
  tls:
    - secretName: "opendesk-certificates-tls"
      hosts:
        - "etherpad.opendesk.example.com"

persistence:
  size: "1Gi"
  storageClass: {{ coalesce .Values.persistence.storages.etherpad.storageClassName .Values.persistence.storageClassNames.RWO | quote }}

service:
  annotations:
    {{ .Values.annotations.etherpad.service | toYaml | nindent 4 }}
  externalPort: 9001
  enabled: true

serviceAccount:
  annotations:
    {{ .Values.annotations.etherpad.serviceAccount | toYaml | nindent 4 }}

nodeSelector: {}

tolerations: []

affinity: {}

cluster:
  replicas: {{ default 1 .Values.replicas.etherpad }}

postgresql:
  enabled: true
  auth:
    username: "etherpad"
    database: "etherpad"
    existingSecret: ""
  primary:
    persistence:
      enabled: true
      size: "8Gi"
      accessMode: "ReadWriteMany"
